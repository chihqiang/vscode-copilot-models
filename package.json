{
  "name": "vscode-copilot-models",
  "displayName": "Copilot Models",
  "description": "Unlock third-party large model extensions for GitHub Copilot. Support DeepSeek and more LLMs.",
  "version": "0.0.11",
  "publisher": "chihqiang",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/chihqiang/vscode-copilot-models.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "copilot",
    "github copilot",
    "copilot chat",
    "deepseek",
    "qwen",
    "tongyi",
    "alibaba",
    "language model",
    "ai",
    "chat",
    "byok"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "enabledApiProposals": [
    "languageModelThinkingPart"
  ],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "copilot-models-router",
        "displayName": "Copilot Models"
      },
      {
        "vendor": "deepseek",
        "displayName": "DeepSeek"
      },
      {
        "vendor": "bigmodel",
        "displayName": "BigModel"
      },
      {
        "vendor": "qwen",
        "displayName": "Qwen"
      }
    ],
    "commands": [
      {
        "command": "copilot-models.setApiKey",
        "title": "Set API Key",
        "description": "Configure API key for model provider (select provider first)"
      },
      {
        "command": "copilot-models.clearApiKey",
        "title": "Clear API Key",
        "description": "Remove stored API key (select provider first)"
      },
      {
        "command": "copilot-models.openSettings",
        "title": "Open Settings",
        "description": "Open extension settings"
      },
      {
        "command": "copilot-models.showLog",
        "title": "Show Log",
        "description": "Show the Copilot Models log panel"
      },
      {
        "command": "copilot-models.clearLog",
        "title": "Clear Log",
        "description": "Clear the Copilot Models log panel"
      },
      {
        "command": "copilot-models.refreshModels",
        "title": "Refresh Models",
        "description": "Refresh the model list"
      },
      {
        "command": "copilot-models.showLatencyStats",
        "title": "Show Latency Stats",
        "description": "Show model routing latency statistics"
      }
    ],
    "configuration": {
      "title": "Copilot Models",
      "properties": {
        "copilot-models.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum tokens to generate (0 = unlimited)"
        },
        "copilot-models.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "description": "Log verbosity: minimal (warnings+errors only), metadata (normal), verbose (debug)"
        },
        "copilot-models.timeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "description": "API request timeout in milliseconds (default: 60000)"
        },
        "copilot-models.maxRetries": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 10,
          "description": "Maximum number of API request retries (default: 1)"
        },
        "copilot-models.modelIdOverrides": {
          "type": "object",
          "default": {},
          "description": "Override model IDs for custom API endpoints",
          "additionalProperties": {
            "type": "string"
          }
        },
        "copilot-models.maxImageSize": {
          "type": "number",
          "default": 20971520,
          "minimum": 0,
          "maximum": 104857600,
          "description": "Maximum image upload size in bytes (default: 20MB, 0 = disabled)"
        },
        "copilot-models.routingStrategy": {
          "type": "string",
          "default": "failover",
          "enum": [
            "failover",
            "latency"
          ],
          "description": "Model routing strategy: 'failover' (fallback on error) or 'latency' (prefer lowest-latency provider)"
        },
        "copilot-models.failoverModels": {
          "type": "object",
          "default": {},
          "description": "Model failover mappings: primary model ID → fallback model ID on another provider",
          "additionalProperties": {
            "type": "string"
          }
        },
        "copilot-models.customProviders": {
          "type": "array",
          "default": [],
          "description": "Custom model providers (OpenAI-compatible API). Each entry defines a provider with models, base URL, and API key handling.",
          "items": {
            "type": "object",
            "required": [
              "providerId",
              "providerName",
              "baseUrl"
            ],
            "properties": {
              "providerId": {
                "type": "string",
                "description": "Unique provider identifier (e.g. 'my-provider')"
              },
              "providerName": {
                "type": "string",
                "description": "Display name (e.g. 'My Provider')"
              },
              "baseUrl": {
                "type": "string",
                "description": "OpenAI-compatible API base URL"
              },
              "apiKeyPrompt": {
                "type": "string",
                "description": "Prompt text shown when requesting API key"
              },
              "apiKeyPlaceholder": {
                "type": "string",
                "description": "Placeholder text in API key input"
              },
              "thinkingParamType": {
                "type": "string",
                "enum": [
                  "reasoning_effort",
                  "thinking_enabled",
                  "none"
                ],
                "default": "reasoning_effort",
                "description": "How to send thinking/reasoning parameter"
              },
              "models": {
                "type": "array",
                "description": "Model definitions (if omitted, a single 'default' model is created)",
                "items": {
                  "type": "object",
                  "required": [
                    "id"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Model ID sent to the API"
                    },
                    "name": {
                      "type": "string",
                      "description": "Human-readable model name"
                    },
                    "maxInputTokens": {
                      "type": "number",
                      "description": "Maximum input tokens"
                    },
                    "maxOutputTokens": {
                      "type": "number",
                      "description": "Maximum output tokens"
                    },
                    "toolCalling": {
                      "type": "boolean",
                      "description": "Supports tool/function calling"
                    },
                    "imageInput": {
                      "type": "boolean",
                      "description": "Supports image input"
                    },
                    "thinking": {
                      "type": "boolean",
                      "description": "Supports thinking/reasoning"
                    }
                  }
                }
              }
            }
          }
        },
        "copilot-models.deepseek.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the DeepSeek provider"
        },
        "copilot-models.deepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API base URL"
        },
        "copilot-models.bigmodel.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the BigModel provider"
        },
        "copilot-models.bigmodel.baseUrl": {
          "type": "string",
          "default": "https://open.bigmodel.cn/api/paas/v4",
          "description": "BigModel API base URL"
        },
        "copilot-models.qwen.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Qwen provider"
        },
        "copilot-models.qwen.baseUrl": {
          "type": "string",
          "default": "https://dashscope.aliyuncs.com/compatible-mode/v1",
          "description": "Qwen API base URL"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "lint:ts": "eslint \"src/**/*.ts\" --ext .ts",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules",
    "test": "vscode-test",
    "test:compile": "tsc -p ./",
    "format": "prettier --write \"src/**/*.ts\"",
    "check": "run-s format lint lint:ts lint:md compile",
    "package:vsix": "npx vsce package",
    "package": "run-s compile package:vsix"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.39.3",
    "glob": "^13.0.6",
    "markdownlint-cli": "^0.48.0",
    "mocha": "^11.7.5",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22"
  }
}
