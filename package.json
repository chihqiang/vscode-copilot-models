{
  "name": "vscode-copilot-models",
  "displayName": "Copilot Models",
  "description": "Unlock third-party large model extensions for GitHub Copilot. Support DeepSeek and more LLMs.",
  "version": "0.1.0",
  "publisher": "copilot-models",
  "repository": {
    "type": "git",
    "url": "https://github.com/chihqiang/vscode-copilot-models.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "copilot",
    "github copilot",
    "copilot chat",
    "deepseek",
    "language model",
    "ai",
    "chat",
    "byok"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "deepseek",
        "displayName": "DeepSeek"
      }
    ],
    "commands": [
      {
        "command": "copilot-models.setApiKey",
        "title": "Set API Key",
        "description": "Configure API key for the selected model provider"
      },
      {
        "command": "copilot-models.clearApiKey",
        "title": "Clear API Key",
        "description": "Remove stored API key"
      },
      {
        "command": "copilot-models.openSettings",
        "title": "Open Settings",
        "description": "Open extension settings"
      }
    ],
    "configuration": {
      "title": "Copilot Models",
      "properties": {
        "copilot-models.deepseekBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API base URL"
        },
        "copilot-models.modelIdOverrides": {
          "type": "object",
          "default": {},
          "description": "Override model IDs for custom API endpoints",
          "additionalProperties": {
            "type": "string"
          }
        },
        "copilot-models.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum tokens to generate (0 = unlimited)"
        },
        "copilot-models.deepseekApiKey": {
          "type": "string",
          "default": "",
          "description": "DeepSeek API key (for CI/automation only, prefer secure storage)"
        },
        "copilot-models.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "description": "Debug mode for logging"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vsce": "^2.15.0"
  }
}
